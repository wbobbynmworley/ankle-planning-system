# .npmrc - 国内全能稳定镜像配置（2026年推荐）
# 优先使用淘宝官方镜像 (npmmirror)，速度最快、最稳定
registry=https://registry.npmmirror.com/

# 备用镜像（如果淘宝偶尔不稳定，可注释上面一行，启用下面一个）
# registry=https://mirrors.aliyun.com/npm/

# Node.js 二进制文件镜像（node-gyp、node-sass 等编译加速）
disturl=https://npmmirror.com/mirrors/node/

# Electron 二进制镜像（Electron 项目常用）
electron_mirror=https://npmmirror.com/mirrors/electron/

# node-sass / dart-sass 二进制镜像
sass_binary_site=https://npmmirror.com/mirrors/node-sass/

# chromedriver / puppeteer 等浏览器驱动镜像
chromedriver_cdnurl=https://npmmirror.com/mirrors/chromedriver
puppeteer_download_host=https://npmmirror.com/mirrors/puppeteer

# playwright 二进制镜像（如果用 playwright 测试框架）
playwright_download_host=https://npmmirror.com/mirrors/playwright

# fsevents 二进制（macOS 文件系统事件）
fsevents_binary_host_mirror=https://npmmirror.com/mirrors/fsevents/

# sharp / libvips 等图像处理库二进制
sharp_binary_host=https://npmmirror.com/mirrors/sharp-libvips/

# 其他常见二进制加速（可选，根据需要启用）
# canvas_binary_host_mirror=https://npmmirror.com/mirrors/canvas/
# gyp_msvs_version=2019  # Windows 下有时需要指定 VS 版本

# 其他实用设置（可选）
# strict-ssl=false                  # 某些镜像证书问题时临时关闭
# fetch-retries=5                   # 下载失败重试次数
# fetch-retry-mintimeout=20000      # 重试最小等待时间
# fetch-retry-maxtimeout=120000     # 重试最大等待时间
# timeout=60000                     # 整体超时时间（秒）

# 恢复官方源（需要时注释上面 registry，启用下面这行）
# registry=https://registry.npmjs.org/