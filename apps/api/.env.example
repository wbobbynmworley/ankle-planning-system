# NestJS 主后端环境变量（复制为 .env 后填写）
# 本地开发：指向本机 MySQL；生产：指向 TiDB / 其它托管 MySQL
DATABASE_URL="mysql://root:1234@127.0.0.1:3307/ankle_app"

# JWT 签名密钥（生产务必用强随机值）
JWT_SECRET="change-me-in-production"

# Python 算法服务地址
ALGO_SERVICE_URL="http://localhost:8000"

# 允许的前端来源（生产填 Vercel 域名，如 https://ankle-web.vercel.app）
CORS_ORIGIN="http://localhost:3000"

# 监听端口（平台通常自动注入；本地默认 3001）
PORT=3001

# 首次启动自动创建的管理员账号（见 prisma-seed.js）
ADMIN_EMAIL="admin@ankle.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="系统管理员"
